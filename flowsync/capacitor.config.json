{
  "appId": "com.flowsync.app",
  "appName": "FlowSync",
  "webDir": "web",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#1b1b19",
      "showSpinner": false
    }
  }
}
